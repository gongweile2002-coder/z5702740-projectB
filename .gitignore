# Raw hosted data is never committed - it loads from the hosted ZIP via src/data_access.py
data/

# Block raw data files anywhere EXCEPT your committed outputs under results/.
# The deployed app reads precomputed artifacts from results/data/, so results/ IS committed.
*.parquet
*.csv
!results/**

# Secrets / local
.streamlit/secrets.toml
.env
